# =============================================================================
# Bayón Middleware — environment variables
# Copy this file to `.env.local` and fill in REAL values from THIS project's
# Supabase (ERRORES.md #3 — make sure it is the Bayón project, not another one).
# Never leave a value blank: empty env vars cause unpredictable build errors.
# =============================================================================

# ---- Supabase (public — safe in the browser bundle) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-anon-public-key

# ---- Supabase service role (SERVER-ONLY — never NEXT_PUBLIC_, never in client code) ----
SUPABASE_SERVICE_ROLE_KEY=YOUR-service-role-secret-key

# ---- MCP auth: key Whaapy must send to call /api/mcp (used from M1) ----
MCP_API_KEY=CHANGE-ME-strong-random-string

# ---- External searcher (used from M2) ----
BUSCADOR_EXTERNO_URL=https://searcher.example.com/api
BUSCADOR_EXTERNO_API_KEY=CHANGE-ME-if-applicable
